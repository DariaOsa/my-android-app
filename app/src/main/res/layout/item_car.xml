<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:padding="12dp"
    android:orientation="vertical"
    android:background="@drawable/ride_card_bg"
    android:elevation="6dp">

    <!-- 🚗 CAR IMAGE -->
    <ImageView
        android:id="@+id/imgCar"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/car_image" />

    <!-- 🚘 NAME -->
    <TextView
        android:id="@+id/txtCarName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BMW 3 Series"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="8dp" />

    <!-- ⭐ CATEGORY + RATING -->
    <TextView
        android:id="@+id/txtMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Premium • ⭐ 4.6"
        android:textSize="12sp"
        android:textColor="#777" />

    <!-- ⚙️ SPECS -->
    <TextView
        android:id="@+id/txtSpecs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5 seats • Electric • Automatic"
        android:textSize="12sp" />

    <!-- 💶 PRICE -->
    <TextView
        android:id="@+id/txtPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="€12.00 / trip"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="6dp" />

    <!-- 📏 DISTANCE -->
    <TextView
        android:id="@+id/txtDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📏 2.1 km away"
        android:textSize="12sp"
        android:textColor="#777" />

    <!-- 🟢 STATUS -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="READY"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:paddingTop="4dp" />

</LinearLayout>