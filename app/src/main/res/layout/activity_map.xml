<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🗺️ MAP -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 🔘 VIEW LIST BUTTON -->
    <Button
        android:id="@+id/btnViewList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/view_list"
        android:layout_gravity="top|start"
        android:layout_marginTop="90dp"
        android:layout_marginStart="16dp"
        android:backgroundTint="#000000"
        android:textColor="#FFFFFF" />

    <!-- 🌍 LANGUAGE SWITCH (FLAGS) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="top|end"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="16dp"
        android:padding="6dp"
        android:background="#66000000">

        <ImageView
            android:id="@+id/imgEnglish"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/flag_en"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/lang_english" />

        <ImageView
            android:id="@+id/imgGreek"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/flag_gr"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/lang_greek" />

    </LinearLayout>

</FrameLayout>