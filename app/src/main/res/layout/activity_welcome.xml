<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="40dp"
        android:contentDescription="@string/app_name" />

    <Button
        android:id="@+id/btnFindCar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/find_car"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#000000"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="30dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/or"
        android:textColor="#888888"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/login"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/register" />

    <!-- 🌍 LANGUAGE SWITCH (FLAGS) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="16dp"
        android:background="#66000000"
        android:orientation="horizontal"
        android:padding="6dp">

        <ImageView
            android:id="@+id/imgEnglish"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:contentDescription="@string/lang_english"
            android:focusable="true"
            android:src="@mipmap/flag_en" />

        <ImageView
            android:id="@+id/imgGreek"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:contentDescription="@string/lang_greek"
            android:focusable="true"
            android:src="@mipmap/flag_gr" />

    </LinearLayout>

</LinearLayout>