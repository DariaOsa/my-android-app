<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#E3F2FD"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape>
            <solid android:color="#FFFFFF"/> <!-- white instead of gray -->
            <corners android:radius="24dp"/>
            <stroke
                android:width="1dp"
                android:color="#E0E0E0"/> <!-- light border -->
        </shape>
    </item>

</selector>