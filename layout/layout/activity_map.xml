<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🗺️ MAP -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 🔵 ROUND VIEW LIST BUTTON (SAFE VERSION) -->
    <Button
        android:id="@+id/btnViewList"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:text="≡"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/fab_fake"
        android:elevation="8dp" />

    <!-- 🚗 RIDE OVERLAY -->

    <LinearLayout
        android:id="@+id/rideOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:background="@drawable/ride_card_bg"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtRideInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚗 Ride in progress"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <Button
            android:id="@+id/btnEndRide"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/btn_danger"
            android:text="End Ride"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/logout_button"
        android:layout_width="112dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:backgroundTint="#C62828"
        android:text="Logout"
        android:textSize="16sp" />

</FrameLayout>

